import { createClient } from '@supabase/supabase-js';

// Initialize Supabase (Use your existing env variables)
const supabase = createClient(
  process.env.SUPABASE_URL,
  process.env.SUPABASE_ANON_KEY
);

export default async function handler(req, res) {
  try {
    // 1. Fetch all 'done' locations to include in the sitemap
    const { data: places, error } = await supabase
      .from('locations')
      .select('id, place_name, updated_at')
      .eq('status', 'done');

    if (error) throw error;

    const baseUrl = 'https://my-journal-viewer.vercel.app';

    // 2. Construct the XML string
    const xml = `<?xml version="1.0" encoding="UTF-8"?>
    <urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
      <url>
        <loc>${baseUrl}/</loc>
        <lastmod>${new Date().toISOString()}</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
      </url>
      
      ${places.map(place => {
        // Create a URL-friendly slug from the place name
        const slug = encodeURIComponent(place.place_name.toLowerCase().replace(/\s+/g, '-'));
        return `
      <url>
        <loc>${baseUrl}/?location=${slug}</loc>
        <lastmod>${new Date(place.updated_at || Date.now()).toISOString()}</lastmod>
        <changefreq>weekly</changefreq>
        <priority>0.8</priority>
      </url>`;
      }).join('')}
    </urlset>`;

    // 3. Send response with XML content type
    res.setHeader('Content-Type', 'text/xml');
    res.write(xml);
    res.end();
  } catch (e) {
    console.error(e);
    res.status(500).send('Error generating sitemap');
  }
}
